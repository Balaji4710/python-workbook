    "import numpy as np\n",
    "Q = np.array([[1, 0, 1]])\n",
    "K = np.array([[1, 1, 0]])\n",
    "V = np.array([[0, 1, 1]])\n",
    "score = np.dot(Q, K.T)\n",
    "attention = score / np.sqrt(3)\n",
    "print(attention)"
   ]
